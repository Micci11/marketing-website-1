---
import type { CollectionEntry } from "astro:content";

const { entry } = Astro.props as { entry: CollectionEntry<"recipes"> };

const img = entry.data.coverImage ?? null;
const recipeHref = `/recipes/${entry.data.slug || entry.id.replace(/\.mdx?$/, "")}/`;
const recipeDate = entry.data.pubDate?.toLocaleDateString();
const totalTime = entry.data.totalTime ?? null;
const mealType = entry.data.mealType?.[0] ?? null;
const tags = entry.data.tags?.slice(0, 3) ?? [];
---

<a
  href={recipeHref}
  class="card-hover group block overflow-hidden rounded-2xl border bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
>
  <div class="relative aspect-[16/9] w-full bg-slate-100 overflow-hidden">
    {img ? (
      <img
        src={img}
        alt={entry.data.coverAlt || entry.data.title}
        class="card-image h-full w-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="h-full w-full bg-gradient-to-br from-emerald-100 via-white to-slate-100" />
    )}

    <div class="card-overlay"></div>
  </div>

  <div class="p-5">
    <h3 class="text-base font-semibold leading-snug tracking-tight text-slate-900">
      {entry.data.title}
    </h3>

    <div class="mt-2 text-sm text-slate-600 flex flex-wrap gap-2">
      {mealType && <span>{mealType}</span>}
      {totalTime && <span>• {totalTime}</span>}
      {recipeDate && <span>• {recipeDate}</span>}
    </div>

    <p class="mt-3 text-sm text-slate-700 line-clamp-2">
      {entry.data.description || "A CraveSmart recipe worth making again and again."}
    </p>

    {tags.length ? (
      <div class="mt-4 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs text-slate-700">
            {tag}
          </span>
        ))}
      </div>
    ) : null}
  </div>
</a>