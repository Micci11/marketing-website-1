---
import Logo from './Logo.astro';
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8 py-4 lg:py-5">
    <!-- Left: Brand -->
    <a href="/" class="group flex shrink-0 items-center gap-1">
      <Logo class="h-9 w-9 md:h-10 md:w-10 flex-shrink-0 transition-transform duration-300 group-hover:scale-[1.03]" />
      <span class="-ml-1.5 font-heading text-[1.65rem] md:text-[1.85rem] font-bold tracking-tight text-gray-900 transition-colors group-hover:text-tiffany">
        CraveSmart
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-6 lg:gap-8 xl:gap-10 text-[15px] lg:text-base font-medium text-gray-700">
      <a class="nav-link transition-colors hover:text-tiffany" href="/">Home</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/breakfast">Breakfast</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/dinner">Dinner</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/snacks">Snacks</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/desserts">Desserts</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/supplements">Supplements</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/about">About</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/contact">Contact</a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-button"
      type="button"
      class="md:hidden inline-flex items-center justify-center rounded-full border border-gray-300 bg-white p-2 text-gray-700 shadow-sm transition hover:bg-gray-50"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        id="menu-open-icon"
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>

      <svg
        id="menu-close-icon"
        xmlns="http://www.w3.org/2000/svg"
        class="hidden h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Navigation -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-gray-200 bg-white"
  >
    <nav class="mx-auto max-w-7xl px-4 py-4 flex flex-col text-base font-medium text-gray-700">
      <a class="py-3 border-b border-gray-100 transition-colors hover:text-tiffany" href="/">Home</a>
      <a class="py-3 border-b border-gray-100 transition-colors hover:text-tiffany" href="/breakfast">Breakfast</a>
      <a class="py-3 border-b border-gray-100 transition-colors hover:text-tiffany" href="/dinner">Dinner</a>
      <a class="py-3 border-b border-gray-100 transition-colors hover:text-tiffany" href="/snacks">Snacks</a>
      <a class="py-3 border-b border-gray-100 transition-colors hover:text-tiffany" href="/desserts">Desserts</a>
      <a class="py-3 border-b border-gray-100 transition-colors hover:text-tiffany" href="/supplements">Supplements</a>
      <a class="py-3 border-b border-gray-100 transition-colors hover:text-tiffany" href="/about">About</a>
      <a class="py-3 transition-colors hover:text-tiffany" href="/contact">Contact</a>
    </nav>
  </div>
</header>

<script is:inline>
  function initMobileMenu() {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    const openIcon = document.getElementById('menu-open-icon');
    const closeIcon = document.getElementById('menu-close-icon');

    if (!button || !menu || !openIcon || !closeIcon) return;

    const closeMenu = () => {
      menu.classList.add('hidden');
      button.setAttribute('aria-expanded', 'false');
      openIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
    };

    const openMenu = () => {
      menu.classList.remove('hidden');
      button.setAttribute('aria-expanded', 'true');
      openIcon.classList.add('hidden');
      closeIcon.classList.remove('hidden');
    };

    button.addEventListener('click', () => {
      const isHidden = menu.classList.contains('hidden');
      if (isHidden) {
        openMenu();
      } else {
        closeMenu();
      }
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) {
        closeMenu();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileMenu);
  } else {
    initMobileMenu();
  }
</script>