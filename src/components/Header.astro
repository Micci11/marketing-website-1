---
import Logo from './Logo.astro';
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8 py-4 lg:py-5">
    <!-- Left: Brand -->
    <a href="/" class="group flex shrink-0 items-center gap-1">
      <Logo class="h-9 w-9 md:h-10 md:w-10 flex-shrink-0 transition-transform duration-300 group-hover:scale-[1.03]" />
      <span class="-ml-1.5 font-heading text-[1.65rem] md:text-[1.85rem] font-bold tracking-tight text-gray-900 transition-colors group-hover:text-tiffany">
        CraveSmart
      </span>
    </a>

    <!-- Center: Navigation -->
    <nav class="hidden md:flex items-center gap-6 lg:gap-8 xl:gap-10 text-[15px] lg:text-base font-medium text-gray-700">
      <a class="nav-link transition-colors hover:text-tiffany" href="/">Home</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/breakfast">Breakfast</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/dinner">Dinner</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/snacks">Snacks</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/desserts">Desserts</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/supplements">Supplements</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/about">About</a>
      <a class="nav-link transition-colors hover:text-tiffany" href="/contact">Contact</a>
    </nav>

    <!-- Right: Spacer for balance -->
    <div class="hidden md:block w-10 lg:w-12" aria-hidden="true"></div>
  </div>
</header>