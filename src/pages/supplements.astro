---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Supplements – CraveSmart" 
  description="Coming soon – macro-optimized supplements to fuel your cravings smarter."
>
  <section class="bg-white text-gray-900 py-24 md:py-32 text-center">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-heading font-bold mb-8">
        Supplements
      </h1>
      <p class="text-2xl md:text-3xl mb-12 text-gray-700">
        Coming Soon
      </p>
      <p class="text-xl max-w-3xl mx-auto mb-12 leading-relaxed">
        Our line of macro-optimized supplements — protein, collagen, greens, and more — is almost here. Designed to make indulgence sustainable and cravings smart.
      </p>
      <div class="inline-block bg-tiffany text-white px-10 py-5 rounded-full font-semibold text-xl shadow-lg">
        Stay Tuned – Launching Soon
      </div>
      <p class="mt-8 text-gray-600">
        
      </p>
    </div>
  </section>
</BaseLayout>