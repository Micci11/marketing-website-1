---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { ViewTransitions } from 'astro:transitions';

import "../../styles/global.css";

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;

if (!entry) {
  return Astro.redirect('/404');
}

const { Content } = await render(entry);
const { title, description, verdict, coverImage, macros, category, pubDate } = entry.data;
---
<BaseLayout 
  title={`${title} | CraveSmart`} 
  description={description || "A macro-aware recipe that satisfies cravings smartly."}
>
  <main class="prose prose-lg max-w-4xl mx-auto py-12 px-4 md:px-0">
    <h1 class="text-4xl md:text-5xl font-heading font-bold text-tiffany mb-6">
      {title}
    </h1>

    {description && (
      <p class="text-xl text-gray-700 mb-8 leading-relaxed">
        {description}
      </p>
    )}

    <span class="inline-block px-4 py-2 rounded-full text-base font-semibold mb-10
      {verdict === 'Works' ? 'bg-green-100 text-green-800' : 
       verdict === 'Meh' ? 'bg-yellow-100 text-yellow-800' : 
       'bg-red-100 text-red-800'}">
      Verdict: {verdict}
    </span>


    <!-- Rendering image -->

     {coverImage && (
  <div class="mb-10 rounded-2xl overflow-hidden shadow-lg not-prose max-w-2xl mx-auto">
    <img
      src={coverImage}
      alt={title}
      class="w-full h-auto object-cover"
    />
  </div>
)}

    <div class="prose-headings:text-tiffany prose-a:text-tiffany hover:prose-a:underline">
      <Content />
    </div>

    <!-- Optional: Back link or related recipes -->
    <div class="mt-12 text-center">
      <a href="/" class="text-tiffany hover:text-tiffany-dark font-medium">
        ← Back to All Recipes
      </a>
    </div>
  </main>
</BaseLayout>