---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import "../../styles/global.css";

function toISOTime(time?: string): string | undefined {
  if (!time) return undefined;

  const hourMatch = time.match(/(\d+)\s*hr/i);
  const minuteMatch = time.match(/(\d+)\s*mins?/i);

  let totalMinutes = 0;

  if (hourMatch) totalMinutes += parseInt(hourMatch[1], 10) * 60;
  if (minuteMatch) totalMinutes += parseInt(minuteMatch[1], 10);

  return totalMinutes > 0 ? `PT${totalMinutes}M` : undefined;
}

function ozToG(oz: number): string {
  return `${Math.round(oz * 28.35)}g`;
}

function lbToKg(lb: number): string {
  const kg = lb * 0.453592;
  return kg >= 1 ? `${(Math.round(kg * 100) / 100).toFixed(2)}kg` : `${Math.round(kg * 1000)}g`;
}

function cupsToMl(cups: number): string {
  return `${Math.round(cups * 240)}ml`;
}

function tbspToMl(tbsp: number): string {
  return `${Math.round(tbsp * 15)}ml`;
}

function tspToMl(tsp: number): string {
  return `${Math.round(tsp * 5)}ml`;
}

function parseFraction(input: string): number {
  const normalized = input.trim();

  const fractionMap: Record<string, number> = {
    "¼": 0.25,
    "½": 0.5,
    "¾": 0.75,
    "⅓": 1 / 3,
    "⅔": 2 / 3,
  };

  if (fractionMap[normalized] != null) return fractionMap[normalized];

  if (normalized.includes(" ")) {
    const [whole, frac] = normalized.split(" ");
    return parseFloat(whole) + (fractionMap[frac] ?? 0);
  }

  if (normalized.includes("/")) {
    const [num, den] = normalized.split("/");
    return parseFloat(num) / parseFloat(den);
  }

  return parseFloat(normalized);
}

function convertIngredientToMetric(text: string): string {
  let result = text;

  result = result.replace(
    /(\d+\s\d+\/\d+|\d+\/\d+|[¼½¾⅓⅔]|\d*\.?\d+)\s*lb\b/gi,
    (_, amount) => lbToKg(parseFraction(amount))
  );

  result = result.replace(
    /(\d+\s\d+\/\d+|\d+\/\d+|[¼½¾⅓⅔]|\d*\.?\d+)\s*oz\b/gi,
    (_, amount) => ozToG(parseFraction(amount))
  );

  result = result.replace(
    /(\d+\s\d+\/\d+|\d+\/\d+|[¼½¾⅓⅔]|\d*\.?\d+)\s*cups?\b/gi,
    (_, amount) => cupsToMl(parseFraction(amount))
  );

  result = result.replace(
    /(\d+\s\d+\/\d+|\d+\/\d+|[¼½¾⅓⅔]|\d*\.?\d+)\s*tbsp\b/gi,
    (_, amount) => tbspToMl(parseFraction(amount))
  );

  result = result.replace(
    /(\d+\s\d+\/\d+|\d+\/\d+|[¼½¾⅓⅔]|\d*\.?\d+)\s*tsp\b/gi,
    (_, amount) => tspToMl(parseFraction(amount))
  );

  return result;
}

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');

  return recipes
    .filter((entry) => entry.data.slug)
    .map((entry) => ({
      params: { slug: entry.data.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;

if (!entry || !entry.data.slug) {
  return Astro.redirect('/404');
}

const { Content } = await render(entry);

const {
  title,
  description,
  coverImage,
  coverAlt,
  macros,
  mealType,
  tags,
  pubDate,
  prepTime,
  cookTime,
  totalTime,
  servings,
  ingredientsDry,
  ingredientsWet,
  optionalIngredients,
  instructions,
  tips,
  variations,
  storage,
  faq,
  sourceNote,
  affiliateLinks
} = entry.data;

const primaryMealType = mealType?.[0];
const currentSlug = entry.data.slug;

const allIngredients = [
  ...(ingredientsDry || []),
  ...(ingredientsWet || []),
  ...(optionalIngredients || []),
];

const recipeSchema = {
  "@context": "https://schema.org",
  "@type": "Recipe",
  name: title,
  description,
  image: coverImage ? [coverImage] : undefined,
  datePublished: pubDate?.toISOString(),
  recipeYield: servings ? `${servings} servings` : undefined,
  prepTime: toISOTime(prepTime),
  cookTime: toISOTime(cookTime),
  totalTime: toISOTime(totalTime),
  recipeIngredient: allIngredients.length > 0 ? allIngredients : undefined,
  recipeInstructions: instructions?.length
    ? instructions.map((step) => ({
        "@type": "HowToStep",
        text: step,
      }))
    : undefined,
  nutrition: macros
    ? {
        "@type": "NutritionInformation",
        calories: macros.calories != null ? `${macros.calories} calories` : undefined,
        proteinContent: macros.protein != null ? `${macros.protein} g` : undefined,
        carbohydrateContent: macros.carbs != null ? `${macros.carbs} g` : undefined,
        fatContent: macros.fat != null ? `${macros.fat} g` : undefined,
      }
    : undefined,
};

const backHref =
  primaryMealType === 'Desserts' ? '/desserts' :
  primaryMealType === 'Dinner' ? '/dinner' :
  primaryMealType === 'Snack' ? '/snacks' :
  primaryMealType === 'Lunch' ? '/lunch' :
  '/breakfast';

const backLabel =
  primaryMealType === 'Desserts' ? 'Desserts' :
  primaryMealType === 'Dinner' ? 'Dinner' :
  primaryMealType === 'Snack' ? 'Snacks' :
  primaryMealType === 'Lunch' ? 'Lunch' :
  'Breakfast';

const allRecipes = await getCollection('recipes');

const relatedRecipes = allRecipes
  .filter((recipe) => recipe.data.slug)
  .map((recipe) => ({
    ...recipe,
    urlSlug: recipe.data.slug,
  }))
  .filter((recipe) => recipe.data.verdict === 'Works')
  .filter((recipe) => recipe.urlSlug !== currentSlug)
  .filter((recipe) => recipe.data.mealType?.[0] === primaryMealType)
  .sort((a, b) => {
    const aTagMatches = (a.data.tags || []).filter((tag) => (tags || []).includes(tag)).length;
    const bTagMatches = (b.data.tags || []).filter((tag) => (tags || []).includes(tag)).length;

    if (bTagMatches !== aTagMatches) {
      return bTagMatches - aTagMatches;
    }

    return (b.data.pubDate?.getTime() || 0) - (a.data.pubDate?.getTime() || 0);
  })
  .slice(0, 3);
---

<BaseLayout
  title={`${title} | CraveSmart`}
  description={description || "A macro-aware recipe that satisfies cravings smartly."}
  image={coverImage}
  canonical={`/recipes/${currentSlug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(recipeSchema)} />

  <section class="max-w-5xl mx-auto py-10 px-4 md:px-6">
    {mealType && mealType.length > 0 && (
      <p class="text-sm uppercase tracking-wider text-tiffany font-semibold mb-3">
        {mealType.join(' • ')}
      </p>
    )}

    <h1 class="text-4xl md:text-5xl font-heading font-bold text-gray-900 mb-4">
      {title}
    </h1>

    {description && (
      <p class="text-lg md:text-xl text-gray-700 mb-6 max-w-3xl leading-relaxed">
        {description}
      </p>
    )}

    <div class="flex flex-wrap gap-4 items-center mb-8">
      <a
        href="#recipe-card"
        class="inline-flex items-center rounded-full bg-gray-900 text-white px-6 py-3 font-semibold hover:bg-gray-800 transition"
      >
        Jump to Recipe
      </a>

      <button
        type="button"
        onclick="window.print()"
        class="inline-flex items-center rounded-full border border-gray-300 bg-white text-gray-900 px-6 py-3 font-semibold hover:bg-gray-50 transition"
      >
        Print Recipe
      </button>

      {pubDate && (
        <span class="text-sm text-gray-500">
          {pubDate.toLocaleDateString()}
        </span>
      )}
    </div>

    {coverImage && (
      <div class="mb-12 max-w-3xl mx-auto not-prose">
        <div class="recipe-image shadow-lg">
          <img
            src={coverImage}
            alt={coverAlt || title}
          />
        </div>
      </div>
    )}

    <section class="prose prose-lg max-w-3xl mx-auto prose-headings:font-heading prose-headings:text-gray-900 prose-a:text-tiffany hover:prose-a:underline mb-14">
      <Content />
    </section>

    <section id="recipe-card" class="bg-white border border-gray-200 rounded-2xl shadow-lg p-6 md:p-8 scroll-mt-24">
      <div class="flex items-start justify-between gap-4 mb-6">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900">
          {title}
        </h2>

        <button
          type="button"
          onclick="window.print()"
          class="shrink-0 rounded-full border border-gray-300 bg-white px-5 py-2 text-sm font-semibold hover:bg-gray-50 transition"
        >
          Print
        </button>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        {prepTime && (
          <div class="bg-hero-bg/20 rounded-xl p-4 text-center">
            <p class="text-sm text-gray-500">Prep Time</p>
            <p class="text-xl font-bold text-gray-900">{prepTime}</p>
          </div>
        )}
        {cookTime && (
          <div class="bg-hero-bg/20 rounded-xl p-4 text-center">
            <p class="text-sm text-gray-500">Cook Time</p>
            <p class="text-xl font-bold text-gray-900">{cookTime}</p>
          </div>
        )}
        {totalTime && (
          <div class="bg-hero-bg/20 rounded-xl p-4 text-center">
            <p class="text-sm text-gray-500">Total Time</p>
            <p class="text-xl font-bold text-gray-900">{totalTime}</p>
          </div>
        )}
        {servings && (
          <div class="bg-hero-bg/20 rounded-xl p-4 text-center">
            <p class="text-sm text-gray-500">Servings</p>
            <p class="text-xl font-bold text-gray-900">{servings}</p>
          </div>
        )}
      </div>

      {macros && (
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
          <div class="bg-gray-50 rounded-xl p-4 text-center">
            <p class="text-sm text-gray-500">Calories</p>
            <p class="text-2xl font-bold text-gray-900">{macros.calories ?? '-'}</p>
          </div>
          <div class="bg-gray-50 rounded-xl p-4 text-center">
            <p class="text-sm text-gray-500">Protein</p>
            <p class="text-2xl font-bold text-gray-900">{macros.protein ?? '-'}g</p>
          </div>
          <div class="bg-gray-50 rounded-xl p-4 text-center">
            <p class="text-sm text-gray-500">Carbs</p>
            <p class="text-2xl font-bold text-gray-900">{macros.carbs ?? '-'}g</p>
          </div>
          <div class="bg-gray-50 rounded-xl p-4 text-center">
            <p class="text-sm text-gray-500">Fat</p>
            <p class="text-2xl font-bold text-gray-900">{macros.fat ?? '-'}g</p>
          </div>
        </div>
      )}

      <div class="grid md:grid-cols-2 gap-10">
        <div>
          <div class="flex items-center justify-between gap-4 mb-4">
            <h3 class="text-2xl font-heading font-bold text-gray-900">Ingredients</h3>

            <div class="inline-flex rounded-full border border-gray-300 bg-gray-50 p-1" id="unit-toggle">
              <button
                type="button"
                data-unit-button="us"
                class="unit-btn rounded-full px-4 py-1.5 text-sm font-semibold bg-gray-900 text-white"
              >
                US
              </button>
              <button
                type="button"
                data-unit-button="metric"
                class="unit-btn rounded-full px-4 py-1.5 text-sm font-semibold text-gray-700"
              >
                Metric
              </button>
            </div>
          </div>

          <p class="text-sm text-gray-500 mb-5">
            Switch between US and metric measurements. Metric conversions are approximate.
          </p>

          {ingredientsDry && ingredientsDry.length > 0 && (
            <>
              <h4 class="font-semibold text-gray-800 mb-2">Dry Ingredients</h4>
              <ul class="list-disc pl-5 space-y-2 text-gray-700 mb-5">
                {ingredientsDry.map((item) => (
                  <li>
                    <span data-unit="us">{item}</span>
                    <span data-unit="metric" class="hidden">{convertIngredientToMetric(item)}</span>
                  </li>
                ))}
              </ul>
            </>
          )}

          {ingredientsWet && ingredientsWet.length > 0 && (
            <>
              <h4 class="font-semibold text-gray-800 mb-2">Wet Ingredients</h4>
              <ul class="list-disc pl-5 space-y-2 text-gray-700 mb-5">
                {ingredientsWet.map((item) => (
                  <li>
                    <span data-unit="us">{item}</span>
                    <span data-unit="metric" class="hidden">{convertIngredientToMetric(item)}</span>
                  </li>
                ))}
              </ul>
            </>
          )}

          {optionalIngredients && optionalIngredients.length > 0 && (
            <>
              <h4 class="font-semibold text-gray-800 mb-2">Optional</h4>
              <ul class="list-disc pl-5 space-y-2 text-gray-700">
                {optionalIngredients.map((item) => (
                  <li>
                    <span data-unit="us">{item}</span>
                    <span data-unit="metric" class="hidden">{convertIngredientToMetric(item)}</span>
                  </li>
                ))}
              </ul>
            </>
          )}
        </div>

        <div>
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-4">Instructions</h3>
          {instructions && instructions.length > 0 ? (
            <ol class="list-decimal pl-5 space-y-4 text-gray-700">
              {instructions.map((step) => <li>{step}</li>)}
            </ol>
          ) : (
            <p class="text-gray-500">Recipe steps coming soon.</p>
          )}
        </div>
      </div>

      {affiliateLinks && affiliateLinks.length > 0 && (
        <div class="mt-10 pt-8 border-t border-gray-200">
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-4">Shop This Recipe</h3>
          <div class="flex flex-col gap-3">
            {affiliateLinks.map((item) => (
              <a
                href={item.url}
                target="_blank"
                rel="nofollow sponsored noopener noreferrer"
                class="inline-flex w-fit items-center rounded-full border border-gray-300 bg-white px-5 py-3 text-sm font-semibold text-gray-900 hover:bg-gray-50 transition"
              >
                {item.label}
              </a>
            ))}
          </div>
          <p class="text-sm text-gray-500 mt-4">
            This post may contain affiliate links, which means CraveSmart may earn a small commission at no extra cost to you.
          </p>
        </div>
      )}

      {tips && tips.length > 0 && (
        <div class="mt-10 pt-8 border-t border-gray-200">
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-4">Tips</h3>
          <ul class="list-disc pl-5 space-y-2 text-gray-700">
            {tips.map((tip) => <li>{tip}</li>)}
          </ul>
        </div>
      )}

      {variations && variations.length > 0 && (
        <div class="mt-10 pt-8 border-t border-gray-200">
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-4">Variations</h3>
          <ul class="list-disc pl-5 space-y-2 text-gray-700">
            {variations.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      )}

      {storage && storage.length > 0 && (
        <div class="mt-10 pt-8 border-t border-gray-200">
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-4">Storage</h3>
          <ul class="list-disc pl-5 space-y-2 text-gray-700">
            {storage.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      )}

      {faq && faq.length > 0 && (
        <div class="mt-10 pt-8 border-t border-gray-200">
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-4">FAQ</h3>
          <div class="space-y-6">
            {faq.map((item) => (
              <div>
                <h4 class="font-semibold text-gray-900 mb-2">{item.question}</h4>
                <p class="text-gray-700">{item.answer}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      {sourceNote && (
        <div class="mt-10 pt-8 border-t border-gray-200">
          <h3 class="text-2xl font-heading font-bold text-gray-900 mb-4">Source Note</h3>
          <p class="text-gray-700">{sourceNote}</p>
        </div>
      )}
    </section>

    {relatedRecipes.length > 0 && (
      <section class="mt-16">
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-gray-900 mb-8">
          You May Also Like
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedRecipes.map((recipe) => {
            const relatedMealTypes = recipe.data.mealType ?? [];

            return (
              <a
                href={`/recipes/${recipe.urlSlug}`}
                class="card-hover block relative rounded-2xl overflow-hidden shadow-md hover:shadow-xl bg-white"
              >
                {recipe.data.coverImage && (
                  <img
                    src={recipe.data.coverImage}
                    alt={recipe.data.coverAlt || recipe.data.title}
                    class="card-image w-full h-56 object-cover"
                  />
                )}

                <div class="p-5">
                  {relatedMealTypes.length > 0 && (
                    <p class="text-xs uppercase tracking-wider text-tiffany font-semibold mb-2">
                      {relatedMealTypes.join(' • ')}
                    </p>
                  )}

                  <h3 class="text-xl font-bold text-gray-900 mb-2">
                    {recipe.data.title}
                  </h3>

                  {recipe.data.description && (
                    <p class="text-sm text-gray-700 line-clamp-3">
                      {recipe.data.description}
                    </p>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <div class="mt-16 text-center">
      <a
        href={backHref}
        class="text-tiffany hover:underline font-medium text-lg"
      >
        ← Back to {backLabel}
      </a>
    </div>
  </section>

  <script is:inline>
    function initUnitToggle() {
      const savedUnit = localStorage.getItem('cravesmart-units') || 'us';

      function applyUnits(unit) {
        document.querySelectorAll('[data-unit="us"]').forEach((el) => {
          el.classList.toggle('hidden', unit !== 'us');
        });

        document.querySelectorAll('[data-unit="metric"]').forEach((el) => {
          el.classList.toggle('hidden', unit !== 'metric');
        });

        document.querySelectorAll('[data-unit-button]').forEach((btn) => {
          const isActive = btn.dataset.unitButton === unit;
          btn.classList.toggle('bg-gray-900', isActive);
          btn.classList.toggle('text-white', isActive);
          btn.classList.toggle('text-gray-700', !isActive);
        });
      }

      applyUnits(savedUnit);

      document.querySelectorAll('[data-unit-button]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const unit = btn.dataset.unitButton;
          localStorage.setItem('cravesmart-units', unit);
          applyUnits(unit);
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initUnitToggle);
    } else {
      initUnitToggle();
    }
  </script>
</BaseLayout>